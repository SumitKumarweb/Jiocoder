{%- liquid
  assign mobile_menu = section.settings.mobile_menu
  assign logo = section.settings.logo
  assign logo_width = section.settings.logo_width | default: 150
-%}

<div id="mobile-menu-overlay" class="mobile-menu-overlay fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-40 hidden"></div>
<aside
  id="mobile-menu"
  class="mobile-menu fixed top-0 left-0 h-screen w-[450px] bg-white dark:bg-slate-900 shadow-2xl z-50 flex flex-col overflow-hidden transform -translate-x-full transition-transform duration-300"
>
  <!-- Header with Logo -->
  <header class="bg-primary px-6 py-5 flex items-center justify-between text-white shrink-0">
    <div class="flex items-center gap-3">
      {% if logo != blank %}
        <a href="{{ routes.root_url }}" class="flex items-center">
          <img
            src="{{ logo | image_url: width: logo_width }}"
            alt="{{ shop.name }}"
            width="{{ logo_width }}"
            height="{{ logo_width | divided_by: logo.aspect_ratio | round }}"
            loading="eager"
            class="max-h-10 w-auto"
          />
        </a>
      {% else %}
        <div class="size-10 bg-white rounded-lg flex items-center justify-center text-primary">
          <span class="material-symbols-outlined text-3xl font-bold">bolt</span>
        </div>
        <div>
          <h1 class="text-xl font-bold tracking-tight">{{ shop.name }}</h1>
        </div>
      {% endif %}
    </div>
    <button
      id="mobile-menu-close"
      class="size-10 flex items-center justify-center rounded-full hover:bg-white/10 transition-colors"
      aria-label="Close menu"
    >
      <span class="material-symbols-outlined">close</span>
    </button>
  </header>

  <!-- Navigation Content (Scrollable) -->
  <nav class="flex-1 overflow-y-auto custom-scrollbar py-4 px-2">
    {% if mobile_menu != blank %}
      <div class="px-4 mb-2">
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">
          {{ section.settings.menu_title | default: 'Product Categories' }}
        </p>
      </div>

      {% for link in mobile_menu.links %}
        {% if link.links != blank %}
          <!-- Category with Submenu (Accordion) -->
          <details class="group px-2 mobile-menu-item" data-link-handle="{{ link.handle }}">
            <summary
              class="flex items-center justify-between p-3 rounded-lg cursor-pointer hover:bg-primary/5 transition-colors group-open:bg-primary/5"
            >
              <div class="flex items-center gap-3 text-slate-700 dark:text-slate-200">
                {% if link.object.metafields.custom.menu_icon != blank %}
                  <span class="material-symbols-outlined text-primary">{{ link.object.metafields.custom.menu_icon }}</span>
                {% elsif forloop.index <= 10 %}
                  {% assign icons = 'keyboard,mouse,rectangle,usb,headphones,memory,chair_alt,devices,watch,smartphone' | split: ',' %}
                  <span class="material-symbols-outlined text-primary">{{ icons[forloop.index0] }}</span>
                {% endif %}
                <span class="font-medium">{{ link.title }}</span>
              </div>
              <span
                class="material-symbols-outlined text-slate-400 group-open:rotate-180 transition-transform"
              >expand_more</span>
            </summary>
            <div class="pl-12 pr-4 py-2 flex flex-col gap-1">
              {% for child_link in link.links %}
                <a
                  class="py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-primary transition-colors"
                  href="{{ child_link.url }}"
                >
                  {{ child_link.title }}
                </a>
              {% endfor %}
            </div>
          </details>
        {% else %}
          <!-- Single Category Link -->
          <div class="px-2 mobile-menu-item" data-link-handle="{{ link.handle }}">
            <a
              class="flex items-center justify-between p-3 rounded-lg hover:bg-primary/5 transition-colors"
              href="{{ link.url }}"
            >
              <div class="flex items-center gap-3 text-slate-700 dark:text-slate-200">
                {% if link.object.metafields.custom.menu_icon != blank %}
                  <span class="material-symbols-outlined text-primary">{{ link.object.metafields.custom.menu_icon }}</span>
                {% elsif forloop.index <= 10 %}
                  {% assign icons = 'keyboard,mouse,rectangle,usb,headphones,memory,chair_alt,devices,watch,smartphone' | split: ',' %}
                  <span class="material-symbols-outlined text-primary">{{ icons[forloop.index0] }}</span>
                {% endif %}
                <span class="font-medium">{{ link.title }}</span>
              </div>
            </a>
          </div>
        {% endif %}
      {% endfor %}
    {% endif %}

    <hr class="mx-6 my-4 border-slate-100 dark:border-slate-800" />

    <!-- Promotion Blocks -->
    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
        {% if block.type == 'promotion' %}
          <div class="px-4 py-2" {{ block.shopify_attributes }}>
            <div class="bg-primary/10 rounded-xl p-4 flex items-center gap-4">
              {% if block.settings.icon != blank %}
                <div class="size-12 rounded-lg bg-primary flex items-center justify-center text-white">
                  <span class="material-symbols-outlined">{{ block.settings.icon }}</span>
                </div>
              {% endif %}
              <div>
                {% if block.settings.label != blank %}
                  <p class="text-xs font-bold text-primary uppercase">
                    {{ block.settings.label }}
                  </p>
                {% endif %}
                {% if block.settings.title != blank %}
                  <p class="text-sm font-semibold text-slate-800 dark:text-slate-100">
                    {{ block.settings.title }}
                  </p>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    {% endif %}
  </nav>

  <!-- Footer Utilities -->
  <footer class="p-6 border-t border-slate-100 dark:border-slate-800 bg-white dark:bg-slate-900">
    {% if section.blocks.size > 0 %}
      {% assign utility_blocks = section.blocks | where: 'type', 'utility' %}
      {% if utility_blocks.size > 0 %}
        <div class="grid grid-cols-2 gap-4 mb-6">
          {% for block in utility_blocks limit: 2 %}
            <a
              class="flex flex-col items-center gap-2 p-3 rounded-xl bg-slate-50 dark:bg-slate-800/50 hover:bg-primary/5 transition-colors group"
              href="{{ block.settings.url }}"
              {{ block.shopify_attributes }}
            >
              {% if block.settings.icon != blank %}
                <span class="material-symbols-outlined text-slate-500 group-hover:text-primary">{{ block.settings.icon }}</span>
              {% endif %}
              <span class="text-xs font-medium text-slate-700 dark:text-slate-300">
                {{ block.settings.label }}
              </span>
            </a>
          {% endfor %}
        </div>
      {% endif %}
    {% endif %}

    {% if section.settings.show_login_button %}
      <a
        href="{{ routes.account_login_url }}"
        class="w-full bg-primary text-white font-bold py-4 rounded-xl hover:shadow-lg hover:shadow-primary/20 transition-all flex items-center justify-center gap-2"
      >
        <span class="material-symbols-outlined text-xl">account_circle</span>
        {{ section.settings.login_button_text | default: 'Login / Signup' }}
      </a>
    {% endif %}

    {% if section.settings.footer_text != blank %}
      <div class="mt-4 text-center">
        <p class="text-[10px] text-slate-400 font-medium tracking-wide">
          {{ section.settings.footer_text }}
        </p>
      </div>
    {% endif %}
  </footer>
</aside>

<script src="{{ 'mobile-menu.js' | asset_url }}" defer></script>
