 
{%- liquid
  assign selected_product = section.settings.product
  
  if selected_product != blank
    if section.settings.product_title != blank
      assign product_title = section.settings.product_title
    else
      assign product_title = selected_product.title
    endif
    
    if section.settings.product_description != blank
      assign product_description = section.settings.product_description
    else
      assign product_description = selected_product.description | strip_html | truncate: 200
    endif
    
    if section.settings.product_image != blank
      assign product_image = section.settings.product_image
    elsif selected_product.featured_image != blank
      assign product_image = selected_product.featured_image
    else
      assign product_image = blank
    endif
    
    assign button_link = section.settings.button_link | default: selected_product.url
    assign show_price = true
  else
    assign product_title = section.settings.product_title | default: "Titan-X Pro Mouse"
    assign product_description = section.settings.product_description | default: "Engineered for endurance during long coding sprints. Explore the technical innovation that powers our flagship peripheral."
    assign product_image = section.settings.product_image
    assign button_link = section.settings.button_link | default: "#"
    assign show_price = false
  endif
  
  assign button_text = section.settings.button_text | default: "Pre-order Now"
-%}

<div class="container mx-auto mt-10">
  <section
    class="bg-primary/50 border border-white/10 rounded-3xl p-8 lg:p-16 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center max-w-7xl mx-auto"
  >
  <div class="space-y-6">
    <h3 class="text-4xl font-bold text-brand-green">{{ product_title }}</h3>
    {% if show_price and selected_product.price %}
      <div class="flex items-center gap-3">
        <span class="text-2xl font-bold text-brand-green">{{ selected_product.price | money }}</span>
        {% if selected_product.compare_at_price > selected_product.price %}
          <span class="text-lg text-slate-500 line-through">{{ selected_product.compare_at_price | money }}</span>
          <span class="text-sm font-semibold text-red-400 bg-red-400/10 px-2 py-1 rounded">
            {{ selected_product.compare_at_price | minus: selected_product.price | times: 100.0 | divided_by: selected_product.compare_at_price | round }}% OFF
          </span>
        {% endif %}
      </div>
    {% endif %}
    <p class="text-slate-400 text-lg">
      {{ product_description }}
    </p>
    {% if section.blocks.size > 0 %}
      <ul class="space-y-4">
        {% for block in section.blocks %}
          {% if block.type == 'feature' %}
            <li class="flex items-center gap-3 text-slate-200" {{ block.shopify_attributes }}>
              <span class="material-symbols-outlined text-brand-blue">{{ block.settings.icon | default: "check_circle" }}</span>
              <span>{{ block.settings.feature_text }}</span>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    {% endif %}
    <button
      onclick="window.location.href='{{ button_link }}'"
      class="bg-brand-green text-primary px-8 py-3 rounded-lg font-bold hover:brightness-110 transition-all"
    >
      {{ button_text }}
    </button>
  </div>
  <div class="relative group">
    {% if product_image != blank %}
      <img
        alt="{{ product_title }}"
        class="w-full h-auto rounded-2xl shadow-2xl transition-all duration-500"
        src="{{ product_image | image_url: width: 800 }}"
        width="{{ product_image.width | default: 800 }}"
        height="{{ product_image.height | default: 600 }}"
        loading="lazy"
      >
    {% else %}
      <img
        alt="{{ product_title }}"
        class="w-full h-auto rounded-2xl shadow-2xl transition-all duration-500"
        src="https://lh3.googleusercontent.com/aida-public/AB6AXuAKPTnPR2ZYt_a6VaISccTem49dOMrTwIeqIByZotD0MSDbynXY1x4jRH3kg8-Zh-qrbNn1w0WLg2nfSAzcB8STxJNCIKxO5SUb6EHtAd-_H9SntE78Ey0byBkeSf2PMVLS-ndiYmeQaWRKT5ZdiF4DIJh837aYSuixZD12MhQQN2TxFwEvl014VM1X3bhPHDJmuFIxzRrjbiYKMIu6nIdy13CpeF94iJsBTtzZLSLKI4FKoZrqif0csbfYmFwMxn0qhzkkrBNVyjWB"
        width="800"
        height="600"
        loading="lazy"
      >
    {% endif %}
    {% for block in section.blocks %}
      {% if block.type == 'hotspot' %}
        {%- liquid
          assign shadow_color = block.settings.shadow_color
          if shadow_color == blank
            case block.settings.color
              when 'bg-brand-green'
                assign shadow_color = '#22C55E'
              when 'bg-brand-blue'
                assign shadow_color = '#3b82f6'
              when 'bg-red-500'
                assign shadow_color = '#ef4444'
              when 'bg-yellow-500'
                assign shadow_color = '#eab308'
              when 'bg-purple-500'
                assign shadow_color = '#a855f7'
              when 'bg-pink-500'
                assign shadow_color = '#ec4899'
              when 'bg-orange-500'
                assign shadow_color = '#f97316'
              else
                assign shadow_color = '#22C55E'
            endcase
          endif
        -%}
        <div
          class="absolute {{ block.settings.position }} group-hover:scale-110 transition-transform"
          {{ block.shopify_attributes }}
        >
          <div class="relative cursor-pointer group/tip">
            <div
              class="w-6 h-6 {{ block.settings.color }} rounded-full hotspot-pulse flex items-center justify-center"
              style="box-shadow: 0 0 15px {{ shadow_color }};"
            >
              <span
                class="material-symbols-outlined {{ block.settings.icon_color }} text-xs font-bold"
                >{{ block.settings.icon | default: "add" }}</span
              >
            </div>
            <div
              class="absolute {{ block.settings.tooltip_position }} left-1/2 -translate-x-1/2 bg-white text-primary p-3 rounded-lg w-48 shadow-xl opacity-0 {{ block.settings.tooltip_animation }} pointer-events-none group-hover/tip:opacity-100 group-hover/tip:translate-y-0 group-hover/tip:translate-x-0 transition-all z-20"
            >
              <p class="font-bold text-sm">{{ block.settings.hotspot_title }}</p>
              <p class="text-xs">{{ block.settings.hotspot_description }}</p>
              <div
                class="absolute {{ block.settings.arrow_position }} left-1/2 -translate-x-1/2 border-8 border-transparent {{ block.settings.arrow_direction }}"
              ></div>
            </div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
  </section>
</div>

{% schema %}
{
  "name": "Product Section",
  "tag": "section",
  "class": "product-section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Select Product"
    },
    {
      "type": "header",
      "content": "Product Information",
      "info": "When a product is selected, it will automatically use the product's title, description, and image. You can override these below."
    },
    {
      "type": "text",
      "id": "product_title",
      "label": "Custom Title (Optional)",
      "info": "Leave empty to automatically use selected product's title"
    },
    {
      "type": "textarea",
      "id": "product_description",
      "label": "Custom Description (Optional)",
      "info": "Leave empty to automatically use selected product's description"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Custom Image (Optional)",
      "info": "Leave empty to automatically use selected product's featured image"
    },
    {
      "type": "header",
      "content": "Button Settings"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Pre-order Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "info": "Leave empty to use product URL"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon Name",
          "default": "check_circle",
          "info": "Material Symbol icon name (e.g., speed, battery_charging_full)"
        },
        {
          "type": "text",
          "id": "feature_text",
          "label": "Feature Text",
          "default": "Feature description"
        }
      ]
    },
    {
      "type": "hotspot",
      "name": "Hotspot",
      "settings": [
        {
          "type": "text",
          "id": "hotspot_title",
          "label": "Hotspot Title",
          "default": "Feature Title"
        },
        {
          "type": "textarea",
          "id": "hotspot_description",
          "label": "Hotspot Description",
          "default": "Feature description text"
        },
        {
          "type": "select",
          "id": "position",
          "label": "Position",
          "options": [
            {
              "value": "top-1/4 right-1/4",
              "label": "Top Right"
            },
            {
              "value": "top-1/4 left-1/4",
              "label": "Top Left"
            },
            {
              "value": "bottom-1/3 left-1/3",
              "label": "Bottom Left"
            },
            {
              "value": "bottom-1/3 right-1/3",
              "label": "Bottom Right"
            },
            {
              "value": "top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2",
              "label": "Center"
            }
          ],
          "default": "top-1/4 right-1/4"
        },
        {
          "type": "select",
          "id": "color",
          "label": "Hotspot Color",
          "options": [
            {
              "value": "bg-brand-green",
              "label": "Green"
            },
            {
              "value": "bg-brand-blue",
              "label": "Blue"
            },
            {
              "value": "bg-red-500",
              "label": "Red"
            },
            {
              "value": "bg-yellow-500",
              "label": "Yellow"
            },
            {
              "value": "bg-purple-500",
              "label": "Purple"
            },
            {
              "value": "bg-pink-500",
              "label": "Pink"
            },
            {
              "value": "bg-orange-500",
              "label": "Orange"
            }
          ],
          "default": "bg-brand-green"
        },
        {
          "type": "color",
          "id": "shadow_color",
          "label": "Shadow/Glow Color",
          "default": "#22C55E",
          "info": "Color for the glow effect around the hotspot"
        },
        {
          "type": "select",
          "id": "icon_color",
          "label": "Icon Color",
          "options": [
            {
              "value": "text-primary",
              "label": "Primary"
            },
            {
              "value": "text-white",
              "label": "White"
            },
            {
              "value": "text-black",
              "label": "Black"
            }
          ],
          "default": "text-primary"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon Name",
          "default": "add",
          "info": "Material Symbol icon name"
        },
        {
          "type": "select",
          "id": "tooltip_position",
          "label": "Tooltip Position",
          "options": [
            {
              "value": "bottom-full mb-4",
              "label": "Above"
            },
            {
              "value": "top-full mt-4",
              "label": "Below"
            },
            {
              "value": "right-full mr-4 top-1/2 -translate-y-1/2",
              "label": "Left"
            },
            {
              "value": "left-full ml-4 top-1/2 -translate-y-1/2",
              "label": "Right"
            }
          ],
          "default": "bottom-full mb-4"
        },
        {
          "type": "select",
          "id": "tooltip_animation",
          "label": "Tooltip Animation",
          "options": [
            {
              "value": "translate-y-2",
              "label": "Slide Down"
            },
            {
              "value": "-translate-y-2",
              "label": "Slide Up"
            },
            {
              "value": "translate-x-2",
              "label": "Slide Right"
            },
            {
              "value": "-translate-x-2",
              "label": "Slide Left"
            }
          ],
          "default": "translate-y-2"
        },
        {
          "type": "select",
          "id": "arrow_position",
          "label": "Arrow Position",
          "options": [
            {
              "value": "top-full",
              "label": "Top"
            },
            {
              "value": "bottom-full",
              "label": "Bottom"
            },
            {
              "value": "right-full",
              "label": "Right"
            },
            {
              "value": "left-full",
              "label": "Left"
            }
          ],
          "default": "top-full"
        },
        {
          "type": "select",
          "id": "arrow_direction",
          "label": "Arrow Direction",
          "options": [
            {
              "value": "border-t-white",
              "label": "Point Down"
            },
            {
              "value": "border-b-white",
              "label": "Point Up"
            },
            {
              "value": "border-l-white",
              "label": "Point Right"
            },
            {
              "value": "border-r-white",
              "label": "Point Left"
            }
          ],
          "default": "border-t-white"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Section",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "speed",
            "feature_text": "1ms Polling Rate for zero lag"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "battery_charging_full",
            "feature_text": "150-hour Battery Life"
          }
        },
        {
          "type": "hotspot",
          "settings": {
            "hotspot_title": "DPI Switch",
            "hotspot_description": "Quick-toggle between 400 and 26,000 DPI presets.",
            "position": "top-1/4 right-1/4",
            "color": "bg-brand-green",
            "shadow_color": "#22c55e",
            "icon_color": "text-primary",
            "tooltip_position": "bottom-full mb-4",
            "tooltip_animation": "translate-y-2",
            "arrow_position": "top-full",
            "arrow_direction": "border-t-white"
          }
        },
        {
          "type": "hotspot",
          "settings": {
            "hotspot_title": "Ergonomic Grip",
            "hotspot_description": "Textured side-panels for maximum precision and comfort.",
            "position": "bottom-1/3 left-1/3",
            "color": "bg-brand-blue",
            "shadow_color": "#3b82f6",
            "icon_color": "text-white",
            "tooltip_position": "top-full mt-4",
            "tooltip_animation": "-translate-y-2",
            "arrow_position": "bottom-full",
            "arrow_direction": "border-b-white"
          }
        }
      ]
    }
  ]
}
{% endschema %}
