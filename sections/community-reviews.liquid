<section class="space-y-6 mt-10">
  {%- if section.settings.heading != blank or section.settings.description != blank or section.settings.follow_text != blank -%}
    <div class="flex items-end justify-between">
      {%- if section.settings.heading != blank or section.settings.description != blank -%}
        <div class="space-y-1">
          {%- if section.settings.heading != blank -%}
            <h3 class="text-2xl font-bold tracking-tight">{{ section.settings.heading }}</h3>
          {%- endif -%}
          {%- if section.settings.description != blank -%}
            <p class="text-slate-500 text-sm">
              {{ section.settings.description }}
            </p>
          {%- endif -%}
        </div>
      {%- else -%}
        <div></div>
      {%- endif -%}
      {%- if section.settings.follow_text != blank -%}
        {%- if section.settings.follow_url != blank -%}
          <a
            class="text-primary font-semibold text-sm flex items-center gap-1 hover:underline"
            href="{{ section.settings.follow_url }}"
            target="_blank"
            rel="noopener noreferrer"
          >
            {{ section.settings.follow_text }}
            <span class="material-symbols-outlined text-sm">open_in_new</span>
          </a>
        {%- else -%}
          <span class="text-primary font-semibold text-sm flex items-center gap-1">
            {{ section.settings.follow_text }}
            <span class="material-symbols-outlined text-sm">open_in_new</span>
          </span>
        {%- endif -%}
      {%- endif -%}
    </div>
  {%- endif -%}
  <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4">
    {%- for block in section.blocks -%}
      {%- if block.type == 'review' -%}
        <div
          class="relative aspect-square rounded-xl overflow-hidden group cursor-pointer shadow-sm video-review-container"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.video != blank -%}
            <div class="video-wrapper w-full h-full relative">
              {{ block.settings.video | video_tag: 
                image_size: '600x600',
                autoplay: false,
                loop: true,
                controls: false,
                muted: true,
                class: 'w-full h-full object-cover transition-transform duration-500 group-hover:scale-110'
              }}
            </div>
          {%- else -%}
            <div class="w-full h-full bg-slate-200 flex items-center justify-center">
              <span class="text-slate-400 text-sm">No video</span>
            </div>
          {%- endif -%}
          <div
            class="absolute inset-0 bg-black/20 flex items-center justify-center transition-opacity group-hover:opacity-0 play-button-overlay"
          >
            <span class="material-symbols-outlined text-white text-4xl opacity-80">play_circle</span>
          </div>
          <div
            class="absolute inset-0 video-overlay opacity-0 group-hover:opacity-100 transition-opacity flex flex-col justify-end p-4"
          >
            {%- if block.settings.username != blank -%}
              <div class="flex items-center gap-2 mb-2">
                <span class="text-white font-bold text-xs">{{ block.settings.username }}</span>
              </div>
            {%- endif -%}
            {%- if block.settings.review_text != blank -%}
              <p class="text-white text-[10px] leading-tight line-clamp-2 mb-2 italic">
                "{{ block.settings.review_text }}"
              </p>
            {%- endif -%}
            <div class="flex items-center gap-3 text-white">
              <div class="flex items-center gap-1">
                <span class="material-symbols-outlined text-xs fill-1">favorite</span>
                <span class="text-[10px] font-bold">
                  {%- if block.settings.likes_count != blank -%}
                    {{ block.settings.likes_count }}
                  {%- else -%}
                    0
                  {%- endif -%}
                </span>
              </div>
              <div class="flex items-center gap-1">
                <span class="material-symbols-outlined text-xs">chat_bubble</span>
                <span class="text-[10px] font-bold">
                  {%- if block.settings.comments_count != blank -%}
                    {{ block.settings.comments_count }}
                  {%- else -%}
                    0
                  {%- endif -%}
                </span>
              </div>
            </div>
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const videoContainers = document.querySelectorAll('.video-review-container');
    
    videoContainers.forEach(container => {
      const video = container.querySelector('video');
      const playButton = container.querySelector('.play-button-overlay');
      
      if (!video) return;
      
      // Play video on hover
      container.addEventListener('mouseenter', function() {
        if (video.readyState >= 2) {
          video.play().catch(function(error) {
            console.log('Video play failed:', error);
          });
        }
      });
      
      // Pause video when mouse leaves
      container.addEventListener('mouseleave', function() {
        video.pause();
        video.currentTime = 0;
      });
      
      // Click to play/pause
      container.addEventListener('click', function(e) {
        e.preventDefault();
        if (video.paused) {
          video.play().catch(function(error) {
            console.log('Video play failed:', error);
          });
          if (playButton) {
            playButton.style.opacity = '0';
          }
        } else {
          video.pause();
          if (playButton) {
            playButton.style.opacity = '1';
          }
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "Community Reviews",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Community Reviews"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Authentic setup showcases from our premium community."
    },
    {
      "type": "text",
      "id": "follow_text",
      "label": "Follow Link Text",
      "default": "Follow @ElectroCart"
    },
    {
      "type": "url",
      "id": "follow_url",
      "label": "Follow Link URL"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        },
        {
          "type": "text",
          "id": "username",
          "label": "Username",
          "default": "@username",
          "info": "Username or handle (e.g., @tech_guru)"
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review Text",
          "default": "Great product! Highly recommend."
        },
        {
          "type": "text",
          "id": "likes_count",
          "label": "Likes Count",
          "default": "1.2k",
          "info": "Number of likes (e.g., 1.2k, 856, 2.4k)"
        },
        {
          "type": "text",
          "id": "comments_count",
          "label": "Comments Count",
          "default": "48",
          "info": "Number of comments"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Community Reviews",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "username": "@tech_guru",
            "review_text": "The build quality on this custom build is insane. Best desk upgrade this year.",
            "likes_count": "1.2k",
            "comments_count": "48"
          }
        },
        {
          "type": "review",
          "settings": {
            "username": "@mechanical_mind",
            "review_text": "Testing out the sound profile of these new tactile switches. Satisfying!",
            "likes_count": "856",
            "comments_count": "32"
          }
        },
        {
          "type": "review",
          "settings": {
            "username": "@desk_setups",
            "review_text": "Minimalism at its peak. The Keychron K2 fits perfectly in my setup.",
            "likes_count": "2.4k",
            "comments_count": "120"
          }
        }
      ]
    }
  ]
}
{% endschema %}
