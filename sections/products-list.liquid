{%- liquid
  assign use_collection = false
  if section.settings.collection != blank
    assign use_collection = true
  endif
-%}

<section class="space-y-6 mt-10">
  {%- if section.settings.heading != blank -%}
    <h3 class="text-2xl font-bold tracking-tight">{{ section.settings.heading }}</h3>
  {%- endif -%}
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
    {%- if use_collection -%}
      {%- assign product_count = 0 -%}
      {%- for product in section.settings.collection.products -%}
        {%- if product_count < section.settings.products_to_show -%}
          {%- render 'product-card-custom', product: product -%}
          {%- assign product_count = product_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    {%- else -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'product' and block.settings.product != blank -%}
          {%- render 'product-card-custom', product: block.settings.product, block: block -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Products List",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Best Sellers"
    },
    {
      "type": "header",
      "content": "Product Source"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Select a collection to display products. If no collection is selected, use product blocks below."
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to Show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "info": "Number of products to display when using a collection"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "badge_text",
          "label": "Badge Text",
          "info": "Optional badge text (e.g., 'Save 15%', 'Top Rated', 'Best Deal')"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Products List"
    }
  ]
}
{% endschema %}
